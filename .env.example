# LLM API Key - Gemini 2.5 Flash
GOOGLE_API_KEY=YOUR_GEMINI_API_KEY

# LLM Configuration
LLM_PROVIDER=google
LLM_MODEL=gemini-2.0-flash-exp  # Latest: gemini-2.0-flash-exp or gemini-1.5-flash
LLM_TEMPERATURE=0.1

# Embeddings (lightweight)
EMBEDDING_MODEL=all-MiniLM-L6-v2  # Fast & good quality

# Vector Store
VECTOR_STORE_PATH=./chroma_db

# Retrieval
TOP_K_RETRIEVAL=5
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# API
API_HOST=0.0.0.0
API_PORT=8000

# Logging
LOG_LEVEL=INFO
